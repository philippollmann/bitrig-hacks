{
  "configs": {
    "Debug": "debug",
    "Release": "release"
  },
  "name": "Project",
  "options": {
    "groupSortPosition": "bottom",
    "transitivelyLinkDependencies": false
  },
  "settings": {
    "CODE_SIGN_IDENTITY": "-"
  },
  "targets": {
    "RepTrack": {
      "deploymentTarget": "26.0",
      "info": {
        "path": "App/Info.plist",
        "properties": {
          "CFBundleDisplayName": "RepTrack",
          "CFBundleShortVersionString": "1.0",
          "CFBundleVersion": "1",
          "ITSAppUsesNonExemptEncryption": false,
          "NSAppleMusicUsageDescription": "RepTrack uses Apple Music to play your chill and energy playlists and adapt the music to how hard you're working out.",
          "NSCameraUsageDescription": "The front camera is used on-device to track your body movement and count your jumping jacks and running steps. No video is recorded or sent anywhere.",
          "UILaunchScreen": {},
          "UISupportedInterfaceOrientations": [
            "UIInterfaceOrientationPortrait"
          ]
        }
      },
      "platform": "iOS",
      "settings": {
        "ASSETCATALOG_COMPILER_APPICON_NAME": "AppIcon",
        "ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME": "AccentColor",
        "CURRENT_PROJECT_VERSION": "1",
        "MARKETING_VERSION": "1.0",
        "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.new.943a6292-b629-487d-8252-200870cbcf59",
        "PRODUCT_NAME": "$(TARGET_NAME)",
        "SWIFT_VERSION": "5.0",
        "TARGETED_DEVICE_FAMILY": "1"
      },
      "sources": [
        {
          "path": "App"
        }
      ],
      "type": "application"
    }
  }
}
